# HyperEVM Testnet RPC (chain 998)
HYPEREVM_RPC_URL=https://rpc.hyperliquid-testnet.xyz/evm

# Private key for keeper wallet (must hold testnet HYPE for gas)
KEEPER_PRIVATE_KEY=0x...your_keeper_private_key

# Contract addresses (chain 998)
SIGNAL_REGISTRY_ADDRESS=0x7745B22B2C73E422154Fcd1ECD283765c4BF6e8c
EPOCH_SCORING_ADDRESS=0xC9F7345574e8734247556Ed4e30B11851E285bA4
ZENT_STAKING_ADDRESS=0x4E2e7Fd3C85c05697b24743e580B03abCD6d0c65
ZENT_TOKEN_ADDRESS=0x271cd48c1297CacCD810c7B1BCD904f459df7117

# Supabase (create your own project at supabase.com, use the publishable URL)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...your_service_role_key

# Chain ID (998 = HyperEVM Testnet)
CHAIN_ID=998

# Scoring oracle address (derived from KEEPER_PRIVATE_KEY)
SCORING_ORACLE_ADDRESS=0x...derived_from_keeper_pk
