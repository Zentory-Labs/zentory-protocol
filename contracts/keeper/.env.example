# ============================================================
# Keeper env vars
# ============================================================
# Two services consume this file: `index.ts` (epoch settler) and
# `heartbeat.ts` (dead-man's switch). Heartbeat reads ONLY the public
# variables — never give it the private key. Less attack surface.

# --- Shared by both services ---
HYPEREVM_RPC_URL=https://rpc.hyperliquid-testnet.xyz/evm
CHAIN_ID=998

# Supabase (use the project's service_role key — keeper writes audit logs)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...your_service_role_key

# Public address of the keeper wallet (lowercase). The heartbeat reads
# this to look up its own last check-in. Derive it once from KEEPER_PRIVATE_KEY
# (cast wallet address $KEEPER_PRIVATE_KEY) and paste it here.
KEEPER_ADDRESS=0x0000000000000000000000000000000000000000

# --- Settler service only (DO NOT set on heartbeat service) ---
KEEPER_PRIVATE_KEY=0x...your_keeper_private_key

# Contract addresses (chain 998 — HyperEVM Testnet)
SIGNAL_REGISTRY_ADDRESS=0x7745B22B2C73E422154Fcd1ECD283765c4BF6e8c
EPOCH_SCORING_ADDRESS=0xDcB2a366dCD5eE126793523b1BeFd78E32A1694d
ZENT_STAKING_ADDRESS=0x4E2e7Fd3C85c05697b24743e580B03abCD6d0c65
ZENT_TOKEN_ADDRESS=0x271cd48c1297CacCD810c7B1BCD904f459df7117

# Scoring oracle address (same as KEEPER_ADDRESS — keeper is the oracle)
SCORING_ORACLE_ADDRESS=0x0000000000000000000000000000000000000000

# --- Heartbeat service only ---
# Discord webhook URL for alerts. Create one in Discord:
#   Server Settings → Integrations → Webhooks → New Webhook
# Leave unset to disable Discord alerts (heartbeat still logs to stdout).
DISCORD_WEBHOOK_URL=
