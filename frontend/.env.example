# ─────────────────────────────────────────────────────────────
# Zentory Protocol — Frontend Environment Variables
# Copy to .env.local and fill in values
# DO NOT commit .env.local — it is in .gitignore
# ─────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
# Found in: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Blockchain ────────────────────────────────────────────────
# HyperEVM testnet RPC (free, no key required)
NEXT_PUBLIC_HYPEREVM_RPC=https://rpc.hyperliquid-testnet.xyz/evm

# ── WalletConnect ─────────────────────────────────────────────
# Required for WalletConnect v2 support in wagmi
# Get free project ID at: https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# ── Keeper (Server-side only) ─────────────────────────────────
# Private key for the keeper wallet that executes on-chain trades.
# NEVER prefix with NEXT_PUBLIC_ — this must stay server-side only.
# KEEPER_PRIVATE_KEY=0xyour-keeper-private-key
