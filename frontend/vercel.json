{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "git": {
    "deploymentEnabled": {
      "main": false,
      "master": false
    }
  },
  "env": {
    "NEXT_PUBLIC_SUPABASE_URL": "@supabase_url",
    "NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY": "@supabase_anon_key",
    "SENTRY_DSN": "@sentry_dsn"
  },
  "regions": ["iad1"],
  "crons": [
    {
      "path": "api/cron/heartbeat",
      "schedule": "*/30 * * * *"
    }
  ]
}